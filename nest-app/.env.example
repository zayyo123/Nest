# 学习注释：复制本文件为 .env 后，NestJS 启动时会读取这些环境变量。
# .env.example 可以提交到仓库，因为它只放示例值；真正的 .env 不要提交。

# 后端监听端口。
PORT=3000
# JWT_SECRET 用来签发和校验登录 token，生产环境必须换成长随机字符串。
JWT_SECRET=replace-with-a-long-random-secret
# 允许哪个前端地址跨域访问后端；开发环境通常是 Vite 的 5173。
CORS_ORIGIN=http://localhost:5173

# MySQL 连接配置。
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=nestlearn
DB_USER=root
DB_PASSWORD=root
# 学习阶段可用 synchronize 自动建表；生产环境应改为 false 并使用迁移。
DB_SYNCHRONIZE=true
# 数据库刚启动时可能还没准备好，TypeORM 会按下面配置重试连接。
DB_RETRY_ATTEMPTS=10
DB_RETRY_DELAY=3000
